  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "BasicResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "status": { "type": "number" },
          "message": { "type": "string" },
          "body": { 
            "type": "string",
            "nullable": true 
            }
        }
      },
      "ResponseWithBody": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "status": { "type": "number" },
          "message": { "type": "string", "nullable": true },
          "body": {
            "type": "object",
            "additionalProperties": true
            }
        }
      },
      "ResponseNoMessage": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "status": { "type": "number" },
          "message": { 
            "type": "string",
            "nullable": true 
            },
          "body": { 
            "type": "string",
            "nullable": true 
            }
        }
      },
      "DashboardResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "status": { "type": "number" },
          "message": {
            "type": "string",
            "nullable": true 
            },
          "body": {
            "type": "object",
            "properties": {
              "number_of_topics": { "type": "number" },
                "questions_created_last_week": { "type": "number" },
                "topics": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "additionalProperties": true
                    }
                }
            }
          }
        }
      },
      "CheckResponse": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "status": { "type": "number" },
          "message": { 
            "type": "string",
            "nullable": true 
            },
          "body": {
            "type": "object",
            "properties": {
                "correct": { "type": "boolean" },
                "question_id": { "type": "string" }
            }
          }
        }
      }
    }
